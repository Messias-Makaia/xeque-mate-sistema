generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// =====================================================
// USUÁRIOS E PERMISSÕES
// =====================================================

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  senha     String
  nome      String
  ativo     Boolean  @default(true)
  criadoEm  DateTime @default(now())

  criadoPor String?
  criador   User?  @relation("UsuarioCriador", fields: [criadoPor], references: [id], onDelete: SetNull)
  usuariosCriados User[] @relation("UsuarioCriador")

  roles    UserRole[]
  Account  Account[]
  Session  Session[]

  // Auditoria
  auditLogs AuditLog[] @relation("AuditActor")

  // ContaContabil
  contasCriadas      ContaContabil[] @relation("ContaCriada")
  contasAtualizadas  ContaContabil[] @relation("ContaAtualizada")
  contasCanceladas   ContaContabil[] @relation("ContaCancelada")

  // LancamentoContabil
  lancamentosCriados LancamentoContabil[] @relation("LancamentoCriado")

  // PeriodoContabil
  periodosCriados    PeriodoContabil[] @relation("PeriodoCriado")
  periodosAtualizados PeriodoContabil[] @relation("PeriodoAtualizado")

  @@map("users")
}

model Role {
  id        String   @id @default(cuid())
  nome      String   @unique
  descricao String?
  ativo     Boolean  @default(true)
  criadoEm  DateTime @default(now())

  users       UserRole[]
  permissions RolePermission[]

  @@map("roles")
}

model Permission {
  id        String   @id @default(cuid())
  nome      String   @unique
  descricao String?
  recurso   String
  acao      String
  ativo     Boolean  @default(true)
  criadoEm  DateTime @default(now())

  roles RolePermission[]

  @@map("permissions")
}

model UserRole {
  id     String @id @default(cuid())
  userId String
  roleId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  role   Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
  @@map("user_roles")
}

model RolePermission {
  id           String     @id @default(cuid())
  roleId       String
  permissionId String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@map("role_permissions")
}

// ==================== AUTENTICAÇÃO ====================

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("contas")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessoes")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("tokens_verificacao")
}

// =================== AUDITORIA ====================

model AuditLog {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  actorId   String?
  actor     User?    @relation("AuditActor", fields: [actorId], references: [id], onDelete: SetNull)

  action    String
  entity    String
  entityId  String?

  beforeJson Json?
  afterJson  Json?

  ip        String?
  userAgent String?

  @@index([entity, entityId])
  @@index([actorId])
  @@map("audit_logs")
}

// ==================== PLANO DE CONTAS ====================

model ContaContabil {
  id                String   @id @default(cuid())
  codigo            String   @unique
  nome              String
  descricao         String?
  tipo              String   // "ATIVO", "PASSIVO", "CAPITAL", "RECEITA", "CUSTO"
  natureza          String   // "DEVEDORA" ou "CREDORA"
  naturezaResultado Boolean  @default(false) // true = será zerada no encerramento
  nivel             Int
  contaPaiId        String?
  contaPai          ContaContabil?  @relation("HierarquiaConta", fields: [contaPaiId], references: [id])
  subContas         ContaContabil[] @relation("HierarquiaConta")
  aceitaLancamento  Boolean  @default(true)
  ativa             Boolean  @default(true)
  criadaEm          DateTime @default(now())
  atualizadaEm      DateTime @updatedAt

  criadoporId     String
  atualizadoporId String?
  canceladoporId  String?

  criadopor     User  @relation("ContaCriada",     fields: [criadoporId],     references: [id], onDelete: Restrict)
  atualizadopor User? @relation("ContaAtualizada", fields: [atualizadoporId], references: [id], onDelete: SetNull)
  canceladopor  User? @relation("ContaCancelada",  fields: [canceladoporId],  references: [id], onDelete: SetNull)

  itensLancamento ItemLancamento[]

  @@index([codigo])
  @@index([tipo])
  @@map("contas_contabeis")
}

// ==================== PERÍODOS CONTABILÍSTICOS ====================

model PeriodoContabil {
  id          String   @id @default(cuid())
  nome        String
  tipo        String   @default("MES") // "EXERCICIO" ou "MES"
  dataInicio  DateTime
  dataFim     DateTime
  fechado     Boolean  @default(false)
  bloqueado Boolean @default(false)
  criadoEm    DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  // Hierarquia: Exercício -> Meses
  exercicioId String?
  exercicio   PeriodoContabil?  @relation("ExercicioMeses", fields: [exercicioId], references: [id])
  meses       PeriodoContabil[] @relation("ExercicioMeses")

  criadoporId     String
  atualizadoporId String?

  criadopor     User  @relation("PeriodoCriado",     fields: [criadoporId],     references: [id], onDelete: Restrict)
  atualizadopor User? @relation("PeriodoAtualizado", fields: [atualizadoporId], references: [id], onDelete: SetNull)

  lancamentos LancamentoContabil[]

  @@map("periodos_contabeis")
}

// ==================== LANÇAMENTOS CONTÁBEIS ====================

model LancamentoContabil {
  id           String   @id @default(cuid())
  data         DateTime
  descricao    String
  documento    String?
  tipo         String   @default("NORMAL") // "NORMAL", "ESTORNO", "ENCERRAMENTO"
  totalDebito  Decimal  @db.Decimal(15, 2)
  totalCredito Decimal  @db.Decimal(15, 2)
  status       String   @default("ATIVO") // "ATIVO", "CANCELADO", "ESTORNADO"
  observacoes  String?
  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  criadoporId String
  periodoId   String

  periodo   PeriodoContabil @relation(fields: [periodoId], references: [id])
  criadopor User            @relation("LancamentoCriado", fields: [criadoporId], references: [id], onDelete: Restrict)

  lancamentoOriginalId String?
  lancamentoOriginal   LancamentoContabil?  @relation("EstornoOriginal", fields: [lancamentoOriginalId], references: [id], onDelete: Restrict)
  estornos             LancamentoContabil[] @relation("EstornoOriginal")

  itens ItemLancamento[]

  @@map("lancamentos_contabeis")
}

model ItemLancamento {
  id              String  @id @default(cuid())
  lancamentoId    String
  contaContabilId String
  codigoConta     String
  nomeConta       String
  debito          Decimal @db.Decimal(15, 2)
  credito         Decimal @db.Decimal(15, 2)
  criadoEm        DateTime @default(now())

  lancamento    LancamentoContabil @relation(fields: [lancamentoId], references: [id], onDelete: Cascade)
  contaContabil ContaContabil      @relation(fields: [contaContabilId], references: [id])

  @@map("itens_lancamento")
}